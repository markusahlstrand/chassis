{
  "name": "substrat",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint:boundaries": "node tools/boundary-lint.mjs",
    "lint:permissions": "tsx tools/permission-diff.mts",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r build && pnpm -r test",
    "docs:dev": "pnpm --filter @substrat-run/docs dev",
    "docs:build": "pnpm --filter @substrat-run/docs build",
    "docs:preview": "pnpm --filter @substrat-run/docs preview",
    "fsm-demo": "pnpm --filter @substrat-run/demo-fsm",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && pnpm publish -r --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "workerd"
    ]
  }
}
