{
  "name": "substrat",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r build && pnpm -r test",
    "docs:dev": "pnpm --filter @substrat/docs dev",
    "docs:build": "pnpm --filter @substrat/docs build",
    "docs:preview": "pnpm --filter @substrat/docs preview",
    "fsm-demo": "pnpm --filter @substrat-demos/fsm",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
