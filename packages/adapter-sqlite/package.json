  "devDependencies": {
    "@substrat-run/contract-tests": "workspace:^",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
