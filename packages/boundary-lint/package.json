{
  "name": "@substrat-run/boundary-lint",
  "version": "0.0.1",
  "description": "The Substrat layer rules, enforced mechanically — R1–R5 static analysis for module code, in this monorepo or in a standalone vertical",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/substrat-run/substrat.git",
    "directory": "packages/boundary-lint"
  },
  "homepage": "https://github.com/substrat-run/substrat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "substrat-boundary-lint": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
