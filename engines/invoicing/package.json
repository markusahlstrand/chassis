{
  "name": "@substrat/engine-invoicing",
  "version": "0.0.1",
  "description": "Substrat engine: fakturaunderlag — consumes billable events, snapshots lines with provenance, immutable once exported",
  "type": "module",
  "main": "./dist/index.js",
