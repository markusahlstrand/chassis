{
  "name": "@substrat-run/demo-callout",
  "version": "0.0.7",
  "private": true,
  "license": "Apache-2.0",
  "description": "FSM demo vertical (Callout) \u2014 see spec/testrun.md",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "server": "tsx src/server.ts",
    "dev": "concurrently -n api,web -c blue,green \"tsx src/server.ts\" \"pnpm --dir app dev\"",
    "demo": "pnpm run dev",
    "cf:dev": "pnpm --dir app build && wrangler dev --var STANDALONE:true",
    "cf:deploy": "pnpm --dir app build && wrangler deploy",
    "cf:dry-run": "pnpm --dir app build && wrangler deploy --dry-run --outdir dist-worker"
  },
  "dependencies": {
    "@substrat-run/adapter-cloudflare": "workspace:^",
    "@substrat-run/adapter-sqlite": "workspace:^",
    "@substrat-run/contracts": "workspace:^",
    "@substrat-run/control-plane-api": "workspace:^",
    "@substrat-run/engine-invoicing": "workspace:^",
    "@substrat-run/engine-protocol": "workspace:^",
    "@substrat-run/engine-workorder": "workspace:^",
    "@substrat-run/kernel": "workspace:^",
    "@hono/node-server": "^1.13.0",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/better-sqlite3": "^7.6.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.110.0"
  }
}
