    "better-sqlite3": "^12.0.0",
    "hono": "^4.6.0",
    "zod": "^4.4.3",
    "better-auth": "^1.6.23"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
