{
  "name": "@substrat-run/dashboard",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "The Dashboard — Substrat’s tenant-facing self-service surface (the platform vertical). See docs/design/dashboard.md.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "build:web": "pnpm --filter @substrat-run/dashboard-web build",
    "cf:dev": "wrangler dev --var STANDALONE:true --port 8890",
    "cf:deploy": "pnpm run build:web && node ../../tools/preflight-migrations.mjs && wrangler deploy"
  },
  "dependencies": {
    "@substrat-run/adapter-cloudflare": "workspace:^",
    "@substrat-run/adapter-email": "workspace:^",
    "@substrat-run/contracts": "workspace:^",
    "@substrat-run/demo-callout": "workspace:^",
    "@substrat-run/demo-meridian": "workspace:^",
    "@substrat-run/engine-invites": "workspace:^",
    "@substrat-run/engine-invoicing": "workspace:^",
    "@substrat-run/engine-protocol": "workspace:^",
    "@substrat-run/engine-workorder": "workspace:^",
    "@substrat-run/kernel": "workspace:^",
    "@substrat-run/oidc-rp": "workspace:^",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@substrat-run/adapter-sqlite": "workspace:^",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.110.0"
  }
}
